rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isNonAnonymousUser() {
      return isAuthed() &&
        request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isAdminEmail() {
      return isNonAnonymousUser() &&
        request.auth.token.email != null &&
        request.auth.token.email in ["kaisvillanueva7@gmail.com", "juandiegohurt@gmail.com"];
    }

    function isMessageOwner() {
      return isAuthed() &&
        resource.data.authorId == request.auth.uid;
    }

    function isVoteOnlyUpdate() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(["upvotes", "downvotes", "rating"]);
    }

    match /messages/{messageId} {
      // Allow map pins/messages to load even before auth resolves.
      allow read: if true;

      // Writes require a signed-in non-guest user.
      allow create: if isNonAnonymousUser() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isNonAnonymousUser() && isVoteOnlyUpdate();
      allow delete: if isMessageOwner() || isAdminEmail();

      // Each user may write only their own vote document.
      match /votes/{userId} {
        allow read: if true;
        allow create, update, delete: if isNonAnonymousUser() &&
          request.auth.uid == userId;
      }
    }

    match /passwordResets/{email} {
      // Allow password reset operations (temporary - for demo purposes)
      allow read, write: if true;
    }

    match /users/{userId} {
      // Allow users to read and write their own profile data
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }
  }
}
